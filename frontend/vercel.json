{
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' https://accounts.google.com https://www.gstatic.com https://checkout.razorpay.com https://apis.google.com;"
        }
      ]
    }
  ]
}